# Etapa de construcción
FROM node:18-alpine AS builder

WORKDIR /app

# Instalar pnpm
RUN npm install -g pnpm

# Copiar archivos de dependencias
COPY integra-rh-manus/package.json integra-rh-manus/pnpm-lock.yaml ./integra-rh-manus/

# Copiar carpeta de patches si existe (necesaria para pnpm install)
COPY integra-rh-manus/patches ./integra-rh-manus/patches

# Instalar dependencias
WORKDIR /app/integra-rh-manus
RUN pnpm install --frozen-lockfile

# Copiar código fuente
WORKDIR /app
COPY integra-rh-manus ./integra-rh-manus

# Exportar variables de Firebase para que Vite las compile en el bundle
WORKDIR /app/integra-rh-manus

# Forzar rebuild invalidando caché (comentario cambia cada build)
# BUILD_ID: 2026-02-18T05:59:09Z
RUN set -a && source .env.production && set +a && npm run build

# Etapa de producción
FROM node:18-alpine

WORKDIR /app

# Copiar archivos necesarios desde la etapa de construcción
COPY --from=builder /app/integra-rh-manus/dist ./dist
COPY --from=builder /app/integra-rh-manus/package.json ./

# Instalar solo dependencias de producción
RUN npm install --omit=dev --legacy-peer-deps

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

CMD ["node", "dist/index.js"]
